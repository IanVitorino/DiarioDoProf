# Postgres connection string (Neon em prod, Postgres local em dev)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth — secret pra assinar JWT (gere com: openssl rand -base64 32)
AUTH_SECRET=""
# URL pública da app (em prod: https://diariodoprof.vercel.app)
NEXTAUTH_URL="http://localhost:4785"

# Cloudflare R2 — storage de avatares (vazio = usa filesystem local)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# URL pública do bucket (ex: https://pub-xxxxxxxx.r2.dev)
R2_PUBLIC_URL=""
