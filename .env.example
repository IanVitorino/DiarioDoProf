# Postgres connection string (Neon em prod, Postgres local em dev)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth — secret pra assinar JWT (gere com: openssl rand -base64 32)
AUTH_SECRET=""
# URL pública da app (em prod: https://diariodoprof.vercel.app)
NEXTAUTH_URL="http://localhost:4785"

# Vercel Blob — storage de avatares (vazio = usa filesystem local em dev)
# Auto-injetado pelo Vercel quando o Blob store é conectado ao projeto
BLOB_READ_WRITE_TOKEN=""
