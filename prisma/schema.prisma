// DiárioDoProf — Prisma schema
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum NivelEnsino {
  FUNDAMENTAL
  FUNDAMENTAL_I
  FUNDAMENTAL_II
  MEDIO
}

enum TurmaStatus {
  ATIVA
  CONCLUIDA
}

enum ModoCalculo {
  MEDIA
  SOMA
}

enum Turno {
  MATUTINO
  VESPERTINO
  NOTURNO
}

enum TipoAtribuicao {
  TODOS
  SELECIONADOS
}

enum TipoAtividade {
  INDIVIDUAL
  GRUPO
}

model Professor {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  nome         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  turmas     Turma[]
  alunos     Aluno[]
  periodos   Periodo[]
  atividades Atividade[]
  notas      Nota[]
}

model Turma {
  id         String      @id @default(uuid())
  nome       String
  turma      String      @default("A")
  nivel      NivelEnsino
  serie      String
  disciplina String
  escola     String?
  turno      Turno?
  ano        Int
  status     TurmaStatus @default(ATIVA)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  professorId String
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)

  alunos   Aluno[]
  periodos Periodo[]

  @@index([professorId])
}

model Aluno {
  id        String   @id @default(uuid())
  nome      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  professorId String
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
  turmaId     String
  turma       Turma     @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  notas       Nota[]
  atribuicoes AtividadeAluno[]
  grupos      GrupoAluno[]

  @@index([professorId])
  @@index([turmaId])
}

model Periodo {
  id          String      @id @default(uuid())
  ordem       Int
  dataInicio  DateTime?
  dataFim     DateTime?
  modoCalculo ModoCalculo @default(MEDIA)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  professorId String
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
  turmaId     String
  turma       Turma     @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  atividades Atividade[]

  @@unique([turmaId, ordem])
  @@index([professorId])
  @@index([turmaId])
}

model Atividade {
  id              String         @id @default(uuid())
  nome            String
  valorMaximo     Float          @default(10)
  data            DateTime?
  tipo            TipoAtividade  @default(INDIVIDUAL)
  tipoAtribuicao  TipoAtribuicao @default(TODOS)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  professorId String
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
  periodoId   String
  periodo     Periodo   @relation(fields: [periodoId], references: [id], onDelete: Cascade)

  notas        Nota[]
  atribuicoes  AtividadeAluno[]
  grupos       Grupo[]

  @@index([professorId])
  @@index([periodoId])
}

model Grupo {
  id          String   @id @default(uuid())
  nome        String
  tema        String?
  notaGrupo   Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  atividadeId String
  atividade   Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  professorId String

  membros GrupoAluno[]

  @@index([atividadeId])
  @@index([professorId])
}

model GrupoAluno {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  grupoId     String
  grupo       Grupo  @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  alunoId     String
  aluno       Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  professorId String

  @@unique([grupoId, alunoId])
  @@index([alunoId])
  @@index([professorId])
}

model AtividadeAluno {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())

  atividadeId String
  atividade   Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  alunoId     String
  aluno       Aluno     @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  professorId String

  @@unique([atividadeId, alunoId])
  @@index([alunoId])
  @@index([professorId])
}

model Nota {
  id        String   @id @default(uuid())
  valor     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  professorId String
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
  alunoId     String
  aluno       Aluno     @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  atividadeId String
  atividade   Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)

  @@unique([alunoId, atividadeId])
  @@index([professorId])
}
